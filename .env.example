# Security
SECRET_KEY=replace_with_secure_random_string
ENVIRONMENT=development
FRONTEND_ORIGIN=http://localhost:5173

# Firebase & Supabase
FIREBASE_PROJECT_ID=your-firebase-project-id
SUPABASE_URL=http://localhost:54321
SUPABASE_SERVICE_KEY=your-supabase-service-role-key
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# Free-Tier LLM Providers (Key Pools for Rotation)
GEMINI_API_KEY_1=your-gemini-api-key-1
GEMINI_API_KEY_2=your-gemini-api-key-2
# GEMINI_API_KEY_N=...

GROQ_API_KEY_1=your-groq-api-key-1
GROQ_API_KEY_2=your-groq-api-key-2
# GROQ_API_KEY_N=...

OPENROUTER_API_KEY_1=your-openrouter-api-key-1
OPENROUTER_API_KEY_2=your-openrouter-api-key-2
# OPENROUTER_API_KEY_N=...

ELEVENLABS_API_KEY=your-elevenlabs-api-key

# Free-Tier Tools (all free)
SERPER_API_KEY=your-serper-api-key

# Config
MAX_PARALLEL_TASKS=4
MOCK_TOOLS=false
